# Copy this file to .env.local and fill in your keys.
# Everything here is read server-side and never sent to the browser source.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: if set, the UI won't ask for a Deepgram key.
# If left out, you can type it into the setup screen instead.
DEEPGRAM_API_KEY=

# Optional — Google Sign-In. Leave blank to run with no login (local use).
# When set, users must sign in with Google and each person's saved
# interviews are scoped to their account.
# Create one at https://console.cloud.google.com/apis/credentials
#   → OAuth client ID → Web application
#   → Authorized JavaScript origins: your site URL (e.g. https://yourapp.com
#     and http://localhost:3000 for local testing)
GOOGLE_CLIENT_ID=

# Recommended in production so login sessions survive server restarts.
# Any long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
